{
  "name": "job-finder",
  "version": "1.0.0",
  "description": "Bot para buscar vagas de estagio e enviar alertas no Telegram.",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "dev": "tsx src/main.ts",
    "search-jobs": "tsx src/main.ts",
    "smoke:formatters": "tsx src/scripts/smoke-formatters.ts",
    "smoke:filters": "tsx src/scripts/smoke-filters.ts",
